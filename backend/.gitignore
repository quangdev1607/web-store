*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Project-specific
**/appsettings.*.json
**/ConnectionStrings.*.json

# Database
*.db
*.sqlite
*.sqlite3

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
